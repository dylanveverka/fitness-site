---
interface Props {
  href: string;
  label?: string;
}

const { href, label = "Check Price on Amazon" } = Astro.props;
---

<div class="affiliate-cta">
  <a href={href} target="_blank" rel="noopener noreferrer sponsored" class="affiliate-btn">
    {label}
  </a>
  <p class="disclosure">
    <small>As an Amazon Associate I earn from qualifying purchases.</small>
  </p>
</div>

<style>
  .affiliate-cta {
    text-align: center;
    margin: 2rem 0;
  }

  .affiliate-btn {
    display: inline-block;
    background: #f90;
    color: #111;
    font-weight: 700;
    font-size: 1.05rem;
    padding: 0.8rem 2rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .affiliate-btn:hover {
    background: #e68a00;
  }

  .disclosure {
    margin: 0.5rem 0 0;
    color: #64748b;
    font-size: 0.78rem;
  }
</style>
