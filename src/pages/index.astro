---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";

const title = "Fit on a Budget — Fitness Gear & Nutrition Reviews for College Students";
const description =
  "Honest fitness reviews, macro breakdowns, and gear picks for college students who want real results without overspending.";

const featuredReviews = [
  {
    title: "Is Premier Protein Good for Building Muscle?",
