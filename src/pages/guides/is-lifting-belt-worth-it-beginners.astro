    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.25;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 1.35rem;
    margin: 2.5rem 0 0.75rem;
    color: #0f172a;
  }

  p {
    line-height: 1.75;
    margin: 0.75rem 0;
    color: #334155;
  }

  ul {
    padding-left: 1.25rem;
    line-height: 1.75;
    color: #334155;
  }

  li {
    margin-bottom: 0.5rem;
  }

  .meta {
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 1.5rem;
  }
</style>
