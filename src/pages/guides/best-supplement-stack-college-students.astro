    border-radius: 999px;
  }

  .tier-1 .tier-badge { background: #ea580c; color: #fff; }
  .tier-2 .tier-badge { background: #2563eb; color: #fff; }
  .tier-3 .tier-badge { background: #64748b; color: #fff; }

  .tier-title {
    font-weight: 700;
    font-size: 0.95rem;
    color: #0f172a;
  }

  .tier-cost {
    margin-left: auto;
    font-size: 0.85rem;
    font-weight: 700;
    color: #475569;
  }

  .tier-supplements {
    padding: 0.5rem 1rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .supp-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f1f5f9;
  }

  .supp-row:last-child { border-bottom: none; }

  .supp-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: #0f172a;
    grid-row: 1;
    grid-column: 1;
  }

  .supp-name a {
    color: #ea580c;
    text-decoration: none;
  }

  .supp-name a:hover { text-decoration: underline; }

  .supp-cost {
    grid-row: 1;
    grid-column: 2;
    font-size: 0.85rem;
    font-weight: 700;
    color: #475569;
    white-space: nowrap;
  }

  .supp-desc {
    grid-row: 2;
    grid-column: 1 / -1;
    font-size: 0.82rem;
    color: #64748b;
