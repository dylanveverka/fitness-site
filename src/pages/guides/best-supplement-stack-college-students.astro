  }

  @media (max-width: 600px) {
    .detail-grid { grid-template-columns: 1fr; }
  }

  .detail-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    margin-bottom: 0.35rem;
  }

  .detail-grid > div:first-child {
    font-size: 0.9rem;
    color: #334155;
    line-height: 1.65;
  }

  .detail-stats {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    background: #f8fafc;
    border-radius: 6px;
    padding: 0.45rem 0.65rem;
  }

  .stat-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #94a3b8;
  }

  .stat-val {
    font-size: 0.82rem;
