    border-bottom: 2px solid #e2e8f0;
  }

  .calc-table th:first-child { border-bottom-color: #e2e8f0; }
  .calc-table th:nth-child(2) { background: #fefce8; color: #854d0e; border-bottom-color: #ca8a04; }
  .calc-table th:nth-child(3) { background: #eff6ff; color: #1d4ed8; border-bottom-color: #1d4ed8; }
  .calc-table th:nth-child(4) { background: #fdf4ff; color: #7e22ce; border-bottom-color: #9333ea; }

  .calc-table td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #f1f5f9;
    color: #334155;
  }

  .calc-table tbody tr:last-child td { border-bottom: none; }
