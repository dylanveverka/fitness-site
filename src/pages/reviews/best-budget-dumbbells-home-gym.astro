    border: 1px solid #1e293b;
    border-radius: 0.375rem;
    overflow: hidden;
  }

  .exercise-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    background: #1e293b;
    padding: 0.5rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #64748b;
  }

  .exercise-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    font-size: 0.85rem;
    color: #cbd5e1;
    border-top: 1px solid #1e293b;
    align-items: center;
  }

  .exercise-row:nth-child(even) {
    background: #0d1424;
  }

  .exercise-row span:last-child {
    font-weight: 600;
    color: #f97316;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .picks-grid,
    .comparison-block {
      grid-template-columns: 1fr;
    }

    .weight-row {
      grid-template-columns: 100px 1fr;
    }
  }
</style>
