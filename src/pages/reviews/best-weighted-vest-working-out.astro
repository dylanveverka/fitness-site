    margin-top: 1rem;
  }

  /* Final Verdict */
  .final-verdict {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 10px;
    padding: 1.5rem;
  }

  .final-verdict h2 {
    color: #c2410c;
  }
</style>
