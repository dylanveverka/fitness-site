    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    background: #f8fafc;
    border-left: 3px solid #f97316;
    padding: 0.75rem 1rem;
    border-radius: 0 6px 6px 0;
    margin-bottom: 1rem;
  }

  .spec {
    font-size: 0.82rem;
    color: #475569;
  }

  /* Carrier Grid */
  .carrier-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .carrier-card {
    border-radius: 8px;
    padding: 1.25rem;
    border-top: 4px solid transparent;
  }

  .carrier-traditional {
    background: #f0fdf4;
    border-top-color: #22c55e;
  }

