    max-width: 780px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  header h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: #0f172a;
  }

  .meta {
    font-size: 0.8rem;
    color: #64748b;
    margin: 0 0 2rem;
  }

  section {
    margin-bottom: 2.5rem;
  }

  h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 1rem;
  }

  h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    margin: 1.5rem 0 0.5rem;
  }

