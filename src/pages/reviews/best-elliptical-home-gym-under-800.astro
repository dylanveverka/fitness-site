    color: #f97316;
    text-decoration: none;
  }

  h3 a:hover {
    text-decoration: underline;
  }

  p {
    color: #334155;
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  /* Verdict Box */
  .verdict-box {
    background: #0f172a;
    border-radius: 12px;
    padding: 1.75rem;
    margin: 2rem 0;
  }

  .verdict-box h2 {
    color: #f8fafc;
    margin-bottom: 1.25rem;
  }

  .picks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .pick-card {
    background: #1e293b;
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pick-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f97316;
  }

  .pick-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #f8fafc;
    text-decoration: none;
    line-height: 1.3;
  }

  .pick-title:hover {
    color: #f97316;
  }

  .pick-card p {
    font-size: 0.82rem;
    color: #94a3b8;
    line-height: 1.5;
    margin: 0;
  }

  .pick-price {
    font-size: 0.9rem;
    font-weight: 700;
    color: #4ade80;
    margin-top: auto;
  }

  /* Spec Row */
  .spec-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    background: #f8fafc;
    border-left: 3px solid #f97316;
    padding: 0.75rem 1rem;
    border-radius: 0 6px 6px 0;
    margin-bottom: 1rem;
  }

  .spec {
    font-size: 0.82rem;
    color: #475569;
  }

  /* Elliptical vs Treadmill */
  .vs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
