    line-height: 1.55;
    margin: 0;
  }

  /* Calorie Grid */
  .calorie-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }

  .calorie-card {
    background: #0f172a;
    border-radius: 8px;
    padding: 1.1rem;
  }

  .calorie-card h4 {
    font-size: 0.78rem;
    font-weight: 700;
    color: #f97316;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.35rem;
  }

  .calorie-burn {
    font-size: 1.2rem;
    font-weight: 800;
    color: #4ade80;
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .calorie-card p:last-child {
    font-size: 0.79rem;
    color: #94a3b8;
    line-height: 1.55;
    margin: 0;
  }

  /* Callout Box */
  .callout-box {
    background: #fefce8;
    border: 1px solid #fde047;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    font-size: 0.88rem;
    color: #713f12;
    line-height: 1.65;
    margin-top: 1rem;
  }

  /* Final Verdict */
  .final-verdict {
