    background: #fff;
    border-radius: 8px;
    padding: 1rem;
    border: 1px solid #fed7aa;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .pick-label {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ea580c;
  }

  .pick-title {
    font-weight: 700;
    color: #0f172a;
    text-decoration: none;
    font-size: 0.93rem;
    line-height: 1.3;
  }

  .pick-title:hover { color: #ea580c; }

  .pick-card p {
    font-size: 0.82rem;
    color: #475569;
    margin: 0;
    flex: 1;
  }

  .pick-price {
    font-size: 0.85rem;
    font-weight: 700;
    color: #0f172a;
  }

  /* Motor table */
  .motor-table-wrap {
    margin: 1rem 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
  }

  .motor-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .motor-table thead tr {
    background: #0f172a;
    color: #e2e8f0;
  }

  .motor-table th {
    text-align: left;
    padding: 0.6rem 1rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  .motor-table td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #e2e8f0;
