    margin: 0 0 0.4rem 0;
  }

  .feature-card p {
    font-size: 0.83rem;
    color: #475569;
    margin: 0;
    line-height: 1.55;
  }

  /* Spec row */
  .spec-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    margin: 0.2rem 0 0.75rem;
  }

  .spec { font-size: 0.83rem; color: #475569; }

  /* Callout box */
  .callout-box {
    background: #fefce8;
