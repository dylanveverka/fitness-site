  /* Feature grid */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .feature-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-left: 3px solid #ea580c;
    border-radius: 8px;
    padding: 1rem;
  }

  .feature-card h3 {
    font-size: 0.88rem;
    font-weight: 700;
