    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.1rem;
  }

  /* Exercise grid */
  .exercise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(185px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .exercise-card {
    background: #0f172a;
    border-radius: 8px;
    padding: 1rem;
  }

  .ex-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #ea580c;
    margin-bottom: 0.6rem;
  }

  .exercise-card ul { margin: 0; padding-left: 1.1rem; }

  .exercise-card li { font-size: 0.83rem; color: #cbd5e1; margin-bottom: 0.3rem; }
</style>
