  .damage-card ul { margin: 0; padding-left: 1.2rem; }

  .damage-card li { font-size: 0.84rem; margin-bottom: 0.35rem; color: #334155; }

  /* Spec row */
  .spec-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    margin: 0.2rem 0 0.75rem;
  }

  .spec { font-size: 0.83rem; color: #475569; }

  /* Progression list */
  .progression-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .progression-step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #f8fafc;
