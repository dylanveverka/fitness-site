    font-size: 0.9rem;
    font-weight: 700;
    color: #4ade80;
    margin-top: auto;
  }

  /* Spec Row */
  .spec-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    background: #f8fafc;
    border-left: 3px solid #f97316;
    padding: 0.75rem 1rem;
    border-radius: 0 6px 6px 0;
    margin-bottom: 1rem;
  }

  .spec {
    font-size: 0.82rem;
    color: #475569;
  }

  /* Benefit Grid */
  .benefit-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .benefit-card {
    background: #0f172a;
    border-radius: 8px;
    padding: 1.1rem;
  }

  .benefit-card h4 {
    font-size: 0.85rem;
    font-weight: 700;
    color: #f97316;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.5rem;
  }

  .benefit-card p {
    font-size: 0.81rem;
    color: #94a3b8;
    line-height: 1.6;
    margin: 0;
  }

  /* Type Grid (electric vs manual) */
  .type-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }

  .type-card {
    border-radius: 8px;
    padding: 1.25rem;
    border-top: 4px solid transparent;
  }

  .type-electric {
    background: #f0fdf4;
    border-top-color: #22c55e;
  }

  .type-manual {
    background: #fafaf9;
    border-top-color: #78716c;
  }

  .type-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.2rem;
  }

  .type-price {
    font-size: 0.75rem;
