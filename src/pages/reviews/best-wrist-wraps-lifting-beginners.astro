  }

  h1 {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    line-height: 1.25;
    margin-bottom: 0.5rem;
  }

  h2 {
    font-size: 1.35rem;
    margin: 2.5rem 0 0.75rem;
    color: #0f172a;
  }

  h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.4rem;
  }

  p {
    line-height: 1.75;
    margin: 0.75rem 0;
    color: #334155;
  }

  ul, ol {
    padding-left: 1.25rem;
    line-height: 1.75;
    color: #334155;
  }

  li {
    margin-bottom: 0.5rem;
  }

  .meta {
    font-size: 0.875rem;
    color: #64748b;
    margin-bottom: 1.5rem;
  }

  /* Quick Verdict Box */
  .verdict-box {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-left: 4px solid #f97316;
    border-radius: 0.5rem;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .picks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .pick-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    padding: 1rem;
  }

  .pick-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f97316;
    margin-bottom: 0.4rem;
  }

  .pick-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .pick-detail {
    font-size: 0.8rem;
    color: #64748b;
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }

  .pick-link {
    font-size: 0.8rem;
    font-weight: 600;
    color: #f97316;
    text-decoration: none;
  }

  .pick-link:hover {
    text-decoration: underline;
  }

  /* Stiff vs Flexible comparison */
  .comparison-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1rem 0;
  }

  .compare-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.375rem;
    padding: 1rem 1.1rem;
  }

  .compare-card h3 {
    color: #0f172a;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .compare-card p {
    font-size: 0.875rem;
    color: #475569;
    margin: 0;
    line-height: 1.65;
  }

  /* How-to list */
  .how-to-list {
    padding-left: 1.25rem;
    color: #334155;
    line-height: 1.75;
  }

  .how-to-list li {
    margin-bottom: 0.75rem;
  }

  @media (max-width: 600px) {
    .picks-grid,
    .comparison-block {
      grid-template-columns: 1fr;
    }
  }
</style>
