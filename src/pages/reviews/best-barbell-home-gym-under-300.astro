    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f97316;
  }

  .pick-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #f8fafc;
    text-decoration: none;
    line-height: 1.3;
  }

  .pick-title:hover {
    color: #f97316;
  }

  .pick-card p {
    font-size: 0.82rem;
    color: #94a3b8;
    line-height: 1.5;
    margin: 0;
  }

  .pick-price {
    font-size: 0.9rem;
    font-weight: 700;
    color: #4ade80;
    margin-top: auto;
  }

  /* Spec Row */
  .spec-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    background: #f8fafc;
    border-left: 3px solid #f97316;
