    color: #f97316;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.3rem;
  }

  .spend-range {
    font-size: 0.82rem;
    font-weight: 700;
    color: #4ade80;
    margin: 0 0 0.5rem;
  }

  .spend-card p:last-child {
    font-size: 0.8rem;
    color: #94a3b8;
    line-height: 1.55;
    margin: 0;
  }

  /* Plates Grid */
  .plates-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .plates-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
