    color: #334155;
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  /* Verdict Box */
  .verdict-box {
    background: #0f172a;
    border-radius: 12px;
    padding: 1.75rem;
    margin: 2rem 0;
  }

  .verdict-box h2 {
    color: #f8fafc;
    margin-bottom: 1.25rem;
  }

  .picks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .pick-card {
    background: #1e293b;
    border-radius: 8px;
    padding: 1rem;
