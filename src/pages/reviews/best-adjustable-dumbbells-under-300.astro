    color: #e2e8f0;
  }

  .workout-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .session-label {
    font-size: 1rem;
    font-weight: 800;
    color: #ea580c;
  }

  .session-detail {
