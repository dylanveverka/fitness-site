    line-height: 1.3;
  }

  .pick-title:hover { color: #ea580c; }

  .pick-card p {
    font-size: 0.83rem;
    color: #475569;
    margin: 0;
    flex: 1;
  }

  .pick-price {
    font-size: 0.85rem;
    font-weight: 700;
    color: #0f172a;
    margin-top: 0.25rem;
  }

  /* Fixed vs adjustable comparison */
  .comparison-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }

  @media (max-width: 560px) {
