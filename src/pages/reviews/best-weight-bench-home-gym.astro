    border: 1px solid #e2e8f0;
    border-left: 3px solid #ea580c;
    border-radius: 8px;
    padding: 1rem;
  }

  .feature-card h3 {
    font-size: 0.88rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.4rem 0;
  }

  .feature-card p {
    font-size: 0.83rem;
    color: #475569;
    margin: 0;
    line-height: 1.55;
  }

  /* Spec row */
  .spec-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
    margin: 0.2rem 0 0.75rem;
  }

  .spec {
    font-size: 0.83rem;
    color: #475569;
  }

  /* Exercise grid */
  .exercise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .exercise-card {
    background: #0f172a;
    border-radius: 8px;
    padding: 1rem;
    color: #e2e8f0;
  }

  .exercise-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #ea580c;
    margin-bottom: 0.6rem;
  }

  .exercise-card ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .exercise-card li {
    font-size: 0.83rem;
    color: #cbd5e1;
    margin-bottom: 0.3rem;
  }
</style>
